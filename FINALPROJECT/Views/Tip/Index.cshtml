@model IEnumerable<FINALPROJECT.Models.Tip>
@{
    ViewData["Title"] = "Cooking Tips";
}
<div class="container section-py">
    <div class="text-center mb-5">
        <div class="section-eyebrow mb-2">CHEF WISDOM</div>
        <h2 class="fw-bold">Cooking Tips &amp; Tricks</h2>
        <p class="text-muted">Expert advice from our culinary community</p>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon"><i class="bi bi-lightbulb"></i></div>
            <h4>No tips yet</h4>
            <p class="text-muted">Check back soon for community cooking tips.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var tip in Model)
            {
                <div class="col-md-6 col-lg-6">
                    <div class="sidebar-card h-100 hover-lift">
                        <div class="d-flex align-items-start gap-3">
                            <div class="empty-state-icon" style="width:48px;height:48px;min-width:48px;font-size:1.2rem;margin:0;">
                                <i class="bi bi-lightbulb-fill"></i>
                            </div>
                            <div class="flex-grow-1">
                                <h6 class="fw-bold mb-2">@tip.Title</h6>
                                <p class="text-muted small mb-3">@tip.Content</p>
                                <div class="d-flex align-items-center justify-content-between">
                                    <div class="card-author">
                                        <img src="@(tip.Author?.AvatarUrl ?? "/images/default-avatar.png")" alt="avatar"
                                             onerror="this.src='https://ui-avatars.com/api/?name=Chef&background=C8622A&color=fff&size=26'" />
                                        <span>@(tip.Author?.DisplayName ?? "Chef")</span>
                                    </div>
                                    <button class="btn btn-sm rounded-pill" style="background:var(--primary-light);color:var(--primary);font-size:.75rem;">
                                        <i class="bi bi-heart-fill me-1 text-danger"></i>@tip.LikeCount
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
