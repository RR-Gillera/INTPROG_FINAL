@model IEnumerable<FINALPROJECT.Models.Recipe>
@{
    ViewData["Title"] = "Search Results";
    var query = ViewBag.Query as string ?? "";
}
<div class="container section-py">
    <h2 class="fw-bold mb-1">Search Results</h2>
    <p class="text-muted mb-4">Results for "<strong>@query</strong>"</p>

    @if (!Model.Any())
    {
        <div class="empty-state mx-auto" style="max-width:480px;">
            <div class="empty-state-icon mx-auto mb-4" style="position:relative;">
                <i class="bi bi-search" style="font-size:2rem;"></i>
                <span style="position:absolute;bottom:-4px;right:-4px;background:var(--primary);border-radius:50%;width:22px;height:22px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:.7rem;"><i class="bi bi-question"></i></span>
            </div>
            <h3 class="fw-bold mb-3">No flavors found for this search.</h3>
            <p class="text-muted mb-4">We couldn't find any recipes matching your criteria. Try using broader keywords or different ingredients.</p>
            <form asp-controller="Home" asp-action="Search" method="get" class="mb-3">
                <div class="input-group">
                    <input type="text" name="q" class="form-control rounded-pill-start" placeholder="Try another search…" />
                    <button type="submit" class="btn btn-dark rounded-pill-end px-4">Search</button>
                </div>
            </form>
            <a asp-controller="Recipe" asp-action="Feed" class="small text-muted text-decoration-none text-uppercase" style="letter-spacing:.06em;">
                Browse Popular Recipes
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var recipe in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="recipe-card">
                        <div class="recipe-card-img-wrap">
                            <img src="@recipe.HeroImageUrl" alt="@recipe.Title"
                                 onerror="this.src='https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=400&q=80'" />
                            <span class="card-time-badge"><i class="bi bi-clock me-1"></i>@(recipe.PrepTime + recipe.CookTime) min</span>
                        </div>
                        <div class="recipe-card-body">
                            <a asp-controller="Recipe" asp-action="Detail" asp-route-id="@recipe.Id" class="text-decoration-none text-dark">
                                <h6 class="fw-semibold mb-1">@recipe.Title</h6>
                            </a>
                            <p class="text-muted small mb-2">@recipe.Description</p>
                            <div class="card-author">
                                <img src="@(recipe.Author?.AvatarUrl ?? "/images/default-avatar.png")" alt="avatar"
                                     onerror="this.src='https://ui-avatars.com/api/?name=Chef&background=C8622A&color=fff&size=26'" />
                                <span>@(recipe.Author?.DisplayName ?? "Chef")</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
