@{
    ViewData["Title"] = "Page Not Found";
}
<div class="container section-py text-center">
    <div class="empty-state mx-auto" style="max-width:480px;">
        <div class="empty-state-icon mx-auto mb-4">
            <i class="bi bi-search" style="font-size:2.5rem;"></i>
        </div>
        <div class="section-eyebrow mb-2">ERROR 404</div>
        <h2 class="fw-bold mb-3">Oops! This recipe is missing.</h2>
        <p class="text-muted mb-4">The kitchen is quiet, and this page seems to have simmered away. It might have been moved or deleted.</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary-flavorly rounded-pill px-5 py-2 fw-semibold">
            <i class="bi bi-house-fill me-2"></i>Back to Home
        </a>
    </div>
</div>
