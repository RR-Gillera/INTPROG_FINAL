@model FINALPROJECT.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <h1 class="hero-headline mb-4">
                    Cook more,<br />
                    <em class="text-primary-color fst-italic">stress less,</em><br />
                    share all.
                </h1>
                <p class="text-muted mb-4" style="font-size:1.05rem;max-width:480px;">
                    Join a community of home cooks discovering new flavors, mastering techniques, and sharing their culinary journeys every day.
                </p>
                <div class="d-flex gap-3 flex-wrap">
                    <a asp-controller="Recipe" asp-action="Feed" class="btn btn-primary-flavorly rounded-pill px-4 py-2 fw-semibold">
                        Explore Recipes <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                    <a asp-controller="Video" asp-action="Feed" class="btn btn-ghost-nav rounded-pill px-4 py-2 fw-semibold">
                        Watch Tutorials
                    </a>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="hero-photo-grid">
                    <img src="/images/hero1.jpg" alt="Avocado toast" onerror="this.src='https://images.unsplash.com/photo-1525351484163-7529414344d8?w=400&q=80'" />
                    <img src="/images/hero2.jpg" alt="Latte art" onerror="this.src='https://images.unsplash.com/photo-1509042239860-f550ce710b93?w=400&q=80'" />
                    <img src="/images/hero3.jpg" alt="Salad bowl" onerror="this.src='https://images.unsplash.com/photo-1512621776951-a57141f2eefd?w=400&q=80'" />
                    <img src="/images/hero4.jpg" alt="Grilled steak" onerror="this.src='https://images.unsplash.com/photo-1558030006-450675393462?w=400&q=80'" />
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Stats Bar -->
<div class="stats-bar">
    <div class="container">
        <div class="row g-0">
            <div class="col-6 col-md-3">
                <div class="stat-item py-2">
                    <div class="stat-number">10k+</div>
                    <div class="stat-label">Original Recipes</div>
                </div>
            </div>
            <div class="col-md-auto d-none d-md-flex align-items-stretch px-3"><div class="stat-divider"></div></div>
            <div class="col-6 col-md-3">
                <div class="stat-item py-2">
                    <div class="stat-number">500+</div>
                    <div class="stat-label">Video Tutorials</div>
                </div>
            </div>
            <div class="col-md-auto d-none d-md-flex align-items-stretch px-3"><div class="stat-divider"></div></div>
            <div class="col-6 col-md-3">
                <div class="stat-item py-2">
                    <div class="stat-number">50k</div>
                    <div class="stat-label">Active Cooks</div>
                </div>
            </div>
            <div class="col-md-auto d-none d-md-flex align-items-stretch px-3"><div class="stat-divider"></div></div>
            <div class="col-6 col-md-3">
                <div class="stat-item py-2">
                    <div class="stat-number">2M</div>
                    <div class="stat-label">Meals Shared</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Fresh Inspiration -->
<section class="section-py">
    <div class="container">
        <div class="d-flex align-items-start justify-content-between flex-wrap gap-3 mb-4">
            <div>
                <h2 class="mb-1">Fresh Inspiration</h2>
                <p class="text-muted mb-0">Discover what the community is cooking today.</p>
            </div>
            <div class="tab-pills">
                @foreach (var tab in new[] { "Trending", "Vegetarian", "Beginner", "Quick Meals" })
                {
                    <a asp-action="Index" asp-route-tab="@tab"
                       class="tab-pill @(Model.ActiveTab == tab ? "active" : "")">@tab</a>
                }
            </div>
        </div>

        @if (!Model.TrendingRecipes.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon"><i class="bi bi-egg-fried"></i></div>
                <h4>No recipes yet</h4>
                <p class="text-muted">Be the first to share a recipe with the community!</p>
                <a asp-controller="Recipe" asp-action="Create" class="btn btn-primary-flavorly rounded-pill px-4">Share First Recipe</a>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var recipe in Model.TrendingRecipes)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="recipe-card">
                            <div class="recipe-card-img-wrap">
                                <img src="@recipe.HeroImageUrl" alt="@recipe.Title"
                                     onerror="this.src='https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=400&q=80'" />
                                <span class="card-time-badge"><i class="bi bi-clock me-1"></i>@(recipe.PrepTime + recipe.CookTime) Min</span>
                                @if (recipe.IsVegetarian)
                                {
                                    <span class="card-tag-badge card-tag-healthy">Vegetarian</span>
                                }
                                else if (recipe.Reviews.Count > 3)
                                {
                                    <span class="card-tag-badge card-tag-trending">Trending</span>
                                }
                                <button class="card-bookmark"><i class="bi bi-heart"></i></button>
                            </div>
                            <div class="recipe-card-body">
                                <a asp-controller="Recipe" asp-action="Detail" asp-route-id="@recipe.Id" class="text-decoration-none text-dark">
                                    <h6 class="fw-semibold mb-1">@recipe.Title</h6>
                                </a>
                                <p class="text-muted small mb-2" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">@recipe.Description</p>
                                <div class="d-flex align-items-center justify-content-between">
                                    <div class="card-author">
                                        <img src="@(recipe.Author?.AvatarUrl ?? "/images/default-avatar.png")" alt="@recipe.Author?.DisplayName"
                                             onerror="this.src='https://ui-avatars.com/api/?name=Chef&background=C8622A&color=fff&size=32'" />
                                        <span>@(recipe.Author?.DisplayName ?? "Chef")</span>
                                    </div>
                                    @if (recipe.Reviews.Any())
                                    {
                                        <div class="star-rating">
                                            <i class="bi bi-star-fill"></i>
                                            <span class="fw-semibold">@recipe.AverageRating.ToString("0.0")</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="text-center mt-5">
                <a asp-controller="Recipe" asp-action="Feed" class="btn btn-outline-secondary rounded-pill px-4 py-2">
                    Load More Recipes <i class="bi bi-arrow-repeat ms-1"></i>
                </a>
            </div>
        }
    </div>
</section>
