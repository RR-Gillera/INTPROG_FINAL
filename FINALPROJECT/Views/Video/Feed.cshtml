@model FINALPROJECT.ViewModels.VideoFeedViewModel
@{
    ViewData["Title"] = "Videos";
    ViewData["BodyClass"] = "dark-page";
    ViewData["NavClass"] = "nav-dark";
}

<!-- Featured Banner -->
<div class="container-fluid px-4 pt-4">
    @if (Model.FeaturedVideo != null)
    {
        var fv = Model.FeaturedVideo;
        <div class="featured-banner mb-5">
            <img src="@fv.ThumbnailUrl" alt="@fv.Title"
                 onerror="this.src='https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=1200&q=80'" />
            <div class="featured-overlay">
                <div style="max-width:520px;">
                    <div class="d-flex gap-2 mb-3">
                        <span class="badge rounded-pill" style="background:var(--primary);font-size:.7rem;">CHEF'S SPECIAL</span>
                        <span class="badge rounded-pill bg-secondary opacity-75" style="font-size:.7rem;">@fv.Duration</span>
                    </div>
                    <h2 class="text-white mb-3" style="font-size:clamp(1.4rem,3vw,2.2rem);">@fv.Title</h2>
                    <div class="d-flex gap-3 align-items-center">
                        <a asp-controller="Video" asp-action="Player" asp-route-id="@fv.Id"
                           class="btn btn-light rounded-pill px-4 py-2 fw-semibold">
                            <i class="bi bi-play-fill me-1"></i>Watch Masterclass
                        </a>
                        <button class="btn btn-outline-light rounded-pill px-3 py-2">
                            <i class="bi bi-bookmark me-1"></i>Save
                        </button>
                        <span class="text-white opacity-75 small">
                            <i class="bi bi-eye me-1"></i>@fv.ViewCount.ToString("N0") watchers
                        </span>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Categories -->
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h5 class="text-white fw-bold mb-0">Explore by Category</h5>
        <div class="d-flex gap-2">
            <button class="btn btn-sm btn-outline-secondary rounded-circle" style="width:32px;height:32px;"><i class="bi bi-chevron-left"></i></button>
            <button class="btn btn-sm btn-outline-secondary rounded-circle" style="width:32px;height:32px;"><i class="bi bi-chevron-right"></i></button>
        </div>
    </div>

    <div class="d-flex gap-2 mb-4 overflow-auto pb-2" style="scrollbar-width:none;">
        @foreach (var cat in Model.Categories)
        {
            <a asp-controller="Video" asp-action="Feed" asp-route-category="@cat"
               class="tab-pill tab-pill-dark text-nowrap @(Model.ActiveCategory == cat ? "active" : "")">@cat</a>
        }
    </div>

    <!-- Video Grid -->
    @if (!Model.Videos.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon" style="background:#2e2620;"><i class="bi bi-camera-video" style="color:#C8622A;"></i></div>
            <h4 class="text-white">No videos yet</h4>
            <p style="color:#9a8f88;">Check back soon for new culinary content.</p>
        </div>
    }
    else
    {
        <div class="row g-4 mb-4">
            @foreach (var v in Model.Videos)
            {
                <div class="col-sm-6 col-lg-4">
                    <div class="video-card">
                        <div class="video-thumb-wrap">
                            <img src="@v.ThumbnailUrl" alt="@v.Title"
                                 onerror="this.src='https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=400&q=80'" />
                            <span class="duration-badge">@v.Duration</span>
                            <div class="play-overlay">
                                <a asp-controller="Video" asp-action="Player" asp-route-id="@v.Id" class="play-btn-circle">
                                    <i class="bi bi-play-fill"></i>
                                </a>
                            </div>
                            <button class="card-bookmark" style="top:8px;right:8px;background:rgba(28,22,18,.7);color:#ccc;"><i class="bi bi-heart"></i></button>
                        </div>
                        <div class="p-3">
                            <div class="d-flex gap-2 mb-2">
                                <span class="badge rounded-pill" style="background:#2e2620;color:#9a8f88;font-size:.68rem;">@v.Category</span>
                            </div>
                            <a asp-controller="Video" asp-action="Player" asp-route-id="@v.Id" class="text-decoration-none">
                                <h6 class="fw-semibold text-white mb-2" style="line-height:1.3;">@v.Title</h6>
                            </a>
                            <div class="card-author">
                                <img src="@(v.Author?.AvatarUrl ?? "/images/default-avatar.png")" alt="avatar"
                                     onerror="this.src='https://ui-avatars.com/api/?name=Chef&background=C8622A&color=fff&size=26'" />
                                <span style="color:#9a8f88;">@(v.Author?.DisplayName ?? "Chef")</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="text-center mb-5">
            <button class="btn btn-outline-secondary rounded-pill px-4 py-2">
                Explore More <i class="bi bi-arrow-down ms-1"></i>
            </button>
        </div>
    }
</div>
