@model FINALPROJECT.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In — Flavorly</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body style="margin:0;padding:0;">
<div class="row g-0" style="min-height:100vh;">
    <!-- Left Dark Panel -->
    <div class="col-lg-5 auth-left d-none d-lg-flex" style="background-image:url('https://images.unsplash.com/photo-1509440159596-0249088772ff?w=800&q=80');background-size:cover;background-position:center;">
        <div style="position:absolute;inset:0;background:rgba(28,22,18,.82);border-radius:0;"></div>
        <div style="position:relative;z-index:1;display:flex;flex-direction:column;justify-content:space-between;padding:3rem;width:100%;">
            <div class="d-flex align-items-center gap-2">
                <span class="brand-dot"></span>
                <span style="font-family:'Playfair Display',serif;font-size:1.35rem;font-weight:700;color:#fff;">Flavorly</span>
            </div>
            <div>
                <div style="color:var(--primary);font-size:2.5rem;font-family:'Playfair Display',serif;line-height:1;">"</div>
                <blockquote style="font-family:'Playfair Display',serif;font-size:1.5rem;color:#fff;line-height:1.4;margin:0.5rem 0 1.5rem;">
                    "Cooking is like love. It should be entered into with abandonment or not at all."
                </blockquote>
                <div style="color:#9a8f88;font-size:.78rem;letter-spacing:.1em;text-transform:uppercase;">— Harriet Van Horne</div>
            </div>
            <div class="d-flex gap-4">
                <a href="#" style="color:#6B5E55;font-size:.85rem;text-decoration:none;">Curated Recipes</a>
                <a href="#" style="color:#6B5E55;font-size:.85rem;text-decoration:none;">Global Community</a>
                <a href="#" style="color:#6B5E55;font-size:.85rem;text-decoration:none;">Chef Masterclasses</a>
            </div>
        </div>
    </div>

    <!-- Right White Panel -->
    <div class="col-lg-7 auth-right">
        <div style="max-width:440px;width:100%;margin:0 auto;">
            <h2 class="fw-bold mb-1" style="font-family:'Playfair Display',serif;">Welcome Back</h2>
            <p class="text-muted mb-4">Continue your culinary journey</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger rounded-3 small py-2">
                    @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    { <div>@err.ErrorMessage</div> }
                </div>
            }

            <form asp-controller="Account" asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ReturnUrl" />

                <div class="mb-4">
                    <label class="form-label small fw-semibold text-uppercase" style="letter-spacing:.06em;">Email Address</label>
                    <div class="auth-input-icon">
                        <i class="bi bi-envelope"></i>
                        <input asp-for="Email" type="email" class="form-control py-3" placeholder="chef@flavorly.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <label class="form-label small fw-semibold text-uppercase mb-0" style="letter-spacing:.06em;">Password</label>
                        <a href="#" class="small text-primary-color text-decoration-none fw-semibold">Forgot?</a>
                    </div>
                    <div class="auth-input-icon">
                        <i class="bi bi-lock"></i>
                        <input asp-for="Password" type="password" class="form-control py-3" placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary-flavorly w-100 rounded-pill py-3 fw-semibold mb-4" style="font-size:1rem;">
                    Sign In
                </button>
            </form>

            <div class="divider-text mb-4">OR CONTINUE WITH</div>

            <div class="row g-3 mb-4">
                <div class="col-6">
                    <button class="btn btn-outline-secondary w-100 rounded-pill py-2">
                        <svg width="18" height="18" viewBox="0 0 48 48" class="me-2"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>
                        Google
                    </button>
                </div>
                <div class="col-6">
                    <button class="btn btn-outline-secondary w-100 rounded-pill py-2">
                        <i class="bi bi-apple me-2"></i>Apple
                    </button>
                </div>
            </div>

            <p class="text-center text-muted mb-0" style="font-size:.9rem;">
                New to Flavorly?
                <a asp-controller="Account" asp-action="Register" class="text-primary-color fw-semibold text-decoration-none">Create an account</a>
            </p>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
