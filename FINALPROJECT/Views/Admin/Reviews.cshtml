@model FINALPROJECT.ViewModels.Admin.AdminReviewsViewModel
@{
    ViewData["Title"] = "Reviews & Reports";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-pill px-4 mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="admin-page-title mb-0">Reviews & Reports</h1>
        <p class="text-muted small">Moderate community feedback and investigate reported content.</p>
    </div>
    <div class="d-flex gap-3 text-center">
        <div class="bg-white rounded px-3 py-2 border shadow-sm">
            <div class="text-muted text-uppercase fw-bold" style="font-size: 0.65rem; letter-spacing: 0.5px;">Pending Reports</div>
            <div class="fw-bold fs-5 text-danger">@Model.PendingReportsCount</div>
        </div>
        <div class="bg-white rounded px-3 py-2 border shadow-sm">
            <div class="text-muted text-uppercase fw-bold" style="font-size: 0.65rem; letter-spacing: 0.5px;">New Reviews</div>
            <div class="fw-bold fs-5 text-dark">@Model.NewReviewsCount</div>
        </div>
    </div>
</div>

<ul class="nav nav-tabs mb-4 px-2" style="border-bottom: 2px solid #f0e9e1;">
    <li class="nav-item">
        <a class="nav-link active fw-bold text-dark border-0 pb-3" style="border-bottom: 3px solid var(--admin-primary) !important; background: transparent; color: var(--admin-primary) !important;" href="#">
            <i class="bi bi-chat-left-text-fill me-2" style="color: var(--admin-primary);"></i> Reviews 
            <span class="badge bg-light text-dark rounded-pill ms-1">@Model.Reviews.Count()</span>
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-muted fw-bold border-0 pb-3" style="background: transparent;" href="#">
            <i class="bi bi-exclamation-triangle-fill me-2 text-muted"></i> Reports
            <span class="badge bg-light text-dark rounded-pill ms-1">@Model.Reports.Count()</span>
        </a>
    </li>
</ul>

<div class="stat-card mb-4 p-3 d-flex gap-3 align-items-center bg-light border-0">
    <div class="input-group flex-grow-1">
        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
        <input type="text" class="form-control border-start-0 ps-0" placeholder="Search by user, recipe title or comment...">
    </div>
    <select class="form-select w-auto"><option>All Ratings</option></select>
    <button class="btn btn-white border px-4"><i class="bi bi-calendar3 me-2"></i> Last 30 Days</button>
</div>

<div class="stat-card p-0 overflow-hidden mb-5">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="text-muted small text-uppercase bg-light" style="font-size: 0.70rem;">
                <tr>
                    <th class="ps-4">Recipe / Item</th>
                    <th>Reviewer</th>
                    <th>Rating</th>
                    <th>Comment Preview</th>
                    <th>Date</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody style="font-size: 0.85rem;">
                @foreach (var rev in Model.Reviews)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center gap-3">
                                <img src="@(rev.Recipe?.HeroImageUrl ?? "/files/default-avatar.png")" class="rounded" width="48" height="40" style="object-fit:cover" />
                                <div class="fw-bold text-dark">@(rev.Recipe?.Title ?? "Unknown Recipe")</div>
                            </div>
                        </td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <img src="/files/default-avatar.png" class="rounded-circle" width="28" height="28" />
                                <div>
                                    <div class="fw-bold text-dark small">@(rev.Author?.DisplayName ?? "Unknown")</div>
                                    <div class="text-muted" style="font-size: 0.65rem;">Member</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="text-warning">
                                @for(int i = 0; i < rev.Rating; i++) { <i class="bi bi-star-fill"></i> }
                                @for(int i = rev.Rating; i < 5; i++) { <i class="bi bi-star text-muted"></i> }
                            </div>
                        </td>
                        <td class="text-muted fst-italic" style="max-width: 250px;">
                            "@(rev.Comment?.Length > 60 ? rev.Comment.Substring(0, 60) + "..." : rev.Comment)"
                        </td>
                        <td class="text-muted small">@rev.CreatedAt.ToString("MMM dd")</td>
                        <td class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-2">
                                <form asp-action="ApproveReview" asp-controller="Admin" asp-route-id="@rev.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm text-success fw-bold bg-success-subtle rounded-pill px-3 border-0">Approve</button>
                                </form>
                                <form asp-action="DeleteReview" asp-controller="Admin" asp-route-id="@rev.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to permanently delete this review?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm text-danger fw-bold bg-danger-subtle rounded-pill px-3 border-0">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<h5 class="fw-bold mb-3 d-flex align-items-center gap-3">Priority Flagged Reports <span class="badge bg-danger-subtle text-danger rounded-pill px-3" style="font-size: 0.6rem;">ACTION REQUIRED</span></h5>
<div class="stat-card p-0 overflow-hidden mb-4">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="text-muted small text-uppercase bg-light border-bottom-0" style="font-size: 0.70rem;">
                <tr>
                    <th class="ps-4">Content Type</th>
                    <th>Title</th>
                    <th>Reported By</th>
                    <th>Reason</th>
                    <th>Status</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody style="font-size: 0.85rem;">
                @foreach(var report in Model.Reports)
                {
                    <tr>
                        <td class="ps-4">
                            <span class="badge bg-dark rounded-pill px-3 py-2 text-uppercase" style="font-size: 0.6rem;">@report.ContentType</span>
                        </td>
                        <td class="fw-bold text-dark">Ref. ID: @report.ContentId</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <img src="/files/default-avatar.png" class="rounded-circle" width="24" height="24" />
                                <span class="text-muted">@(report.ReportedBy?.DisplayName ?? "Unknown")</span>
                            </div>
                        </td>
                        <td>
                            <span class="badge bg-danger-subtle text-danger px-2 border border-danger-subtle">@report.Reason</span>
                        </td>
                        <td>
                            <span class="badge @(report.Status == "PENDING" ? "bg-danger text-white" : "bg-success-subtle text-success") rounded-pill px-2">@report.Status</span>
                        </td>
                        <td class="text-end pe-4">
                            @if(report.Status == "PENDING") {
                                <div class="d-inline-flex gap-1">
                                    <!-- Dismiss Report (Approve / Clear) -->
                                    <form asp-action="DismissReport" asp-controller="Admin" asp-route-id="@report.Id" method="post" class="d-inline" onsubmit="return confirm('Dismiss this report and keep the content active?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-link text-success p-0" title="Dismiss (Keep Content)"><i class="bi bi-check-lg fw-bold px-2 text-success fs-5"></i></button>
                                    </form>

                                    <!-- Resolve Report (Moderate / Delete Content) -->
                                    <form asp-action="ResolveReport" asp-controller="Admin" asp-route-id="@report.Id" method="post" class="d-inline" onsubmit="return confirm('Resolve report by removing the offending content?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-link text-danger p-0" title="Resolve (Delete Content)"><i class="bi bi-trash-fill px-2 text-danger fs-5"></i></button>
                                    </form>
                                </div>
                            } else {
                                <span class="badge bg-light text-muted border px-2 py-1 small">PROCESSED</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    <div class="p-3 border-top d-flex justify-content-between align-items-center bg-white">
        <div class="small text-muted">Showing <strong>1 - @Math.Min(10, Model.Reports.Count())</strong> of <strong>@Model.Reports.Count()</strong> entries</div>
        <div class="d-flex gap-1">
            <button class="btn btn-sm btn-light border">&lt;</button>
            <button class="btn btn-sm text-white border" style="background-color: var(--admin-primary);">1</button>
            <button class="btn btn-sm btn-light border">2</button>
            <button class="btn btn-sm btn-light border">3</button>
            <button class="btn btn-sm btn-light border">&gt;</button>
        </div>
    </div>
</div>