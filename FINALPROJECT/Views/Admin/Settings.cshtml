@model FINALPROJECT.ViewModels.Admin.AdminSettingsViewModel
@{
    ViewData["Title"] = "Settings";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-pill px-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form asp-action="SaveSettings" asp-controller="Admin" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="Settings.Id" value="@Model.Settings.Id" />

    <div class="row">
        <div class="col-12">
            <ul class="nav nav-tabs mb-4" id="settingsTab" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active text-dark fw-semibold" id="general-tab" data-bs-toggle="tab" data-bs-target="#general" type="button" role="tab" aria-controls="general" aria-selected="true" style="border-top: none; border-left: none; border-right: none; border-bottom: 2px solid var(--admin-primary); color: var(--admin-primary) !important;">General</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link text-muted" id="moderation-tab" data-bs-toggle="tab" data-bs-target="#moderation" type="button" role="tab" aria-controls="moderation" aria-selected="false" style="border: none;">Content Moderation</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link text-muted" id="email-tab" data-bs-toggle="tab" data-bs-target="#email" type="button" role="tab" aria-controls="email" aria-selected="false" style="border: none;">Email (SMTP)</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link text-muted" id="account-tab" data-bs-toggle="tab" data-bs-target="#account" type="button" role="tab" aria-controls="account" aria-selected="false" style="border: none;">Admin Account</button>
                </li>
            </ul>

            <div class="tab-content" id="settingsTabContent">
                <div class="tab-pane fade show active" id="general" role="tabpanel" aria-labelledby="general-tab">
                    
                    <div class="stat-card mb-4">
                        <h6 class="fw-bold mb-1">General Configuration</h6>
                        <p class="text-muted small mb-4">Basic site identity and operational status.</p>
                        
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-uppercase text-muted">Site Name</label>
                                <input type="text" name="Settings.SiteName" class="form-control bg-light" value="@Model.Settings.SiteName" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-uppercase text-muted">Tagline</label>
                                <input type="text" name="Settings.Tagline" class="form-control bg-light" value="@Model.Settings.Tagline" />
                            </div>
                            <div class="col-12 mt-4">
                                <div class="d-flex align-items-center justify-content-between p-3 border rounded bg-light">
                                    <div>
                                        <div class="fw-bold small">Maintenance Mode</div>
                                        <div class="text-muted" style="font-size: 0.75rem;">Disable frontend access while performing updates.</div>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input type="hidden" name="Settings.MaintenanceMode" value="false" />
                                        <input class="form-check-input" type="checkbox" name="Settings.MaintenanceMode" value="true" role="switch" @(Model.Settings.MaintenanceMode ? "checked" : "")>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="stat-card mb-4">
                        <h6 class="fw-bold mb-1">Content Moderation</h6>
                        <p class="text-muted small mb-4">Manage how user-generated content is filtered and approved.</p>
                        
                        <div class="d-flex align-items-center justify-content-between mb-4">
                            <div>
                                <div class="fw-bold small">Auto-flagging Keywords</div>
                                <div class="text-muted" style="font-size: 0.75rem;">Automatically flag comments containing profanity or spam.</div>
                            </div>
                            <div class="form-check form-switch">
                                <input type="hidden" name="Settings.AutoFlaggingKeywords" value="false" />
                                <input class="form-check-input" type="checkbox" name="Settings.AutoFlaggingKeywords" value="true" role="switch" @(Model.Settings.AutoFlaggingKeywords ? "checked" : "")>
                            </div>
                        </div>

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-uppercase text-muted">Auto-Hide Reports Threshold</label>
                                <input type="number" name="Settings.AutoHideReportsThreshold" class="form-control bg-light" value="@Model.Settings.AutoHideReportsThreshold" />
                            </div>
                            <div class="col-md-6 d-flex align-items-end">
                                <div class="form-check mb-2">
                                    <input type="hidden" name="Settings.RequireManualApproval" value="false" />
                                    <input class="form-check-input" type="checkbox" name="Settings.RequireManualApproval" value="true" @(Model.Settings.RequireManualApproval ? "checked" : "")>
                                    <label class="form-check-label text-muted small">
                                        Require manual approval for new posts
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="stat-card mb-4">
                        <h6 class="fw-bold mb-1">Email (SMTP) Settings</h6>
                        <p class="text-muted small mb-4">Configure the mail server for system notifications.</p>
                        
                        <div class="row g-4 mb-3">
                            <div class="col-md-8">
                                <label class="form-label small fw-bold text-uppercase text-muted">SMTP Host</label>
                                <input type="text" name="Settings.SmtpHost" class="form-control bg-light" placeholder="smtp.provider.com" value="@Model.Settings.SmtpHost" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-uppercase text-muted">Port</label>
                                <input type="number" name="Settings.SmtpPort" class="form-control bg-light" value="@Model.Settings.SmtpPort" />
                            </div>
                        </div>
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-uppercase text-muted">Username</label>
                                <input type="text" name="Settings.SmtpUsername" class="form-control bg-light" placeholder="admin@example.com" value="@Model.Settings.SmtpUsername" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-uppercase text-muted">Password</label>
                                <input type="password" name="Settings.SmtpPassword" class="form-control bg-light" value="@Model.Settings.SmtpPassword" />
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-3 mt-4">
                        <a href="@Url.Action("Settings", "Admin")" class="btn btn-light fw-semibold rounded-pill px-4 text-decoration-none">Discard Changes</a>
                        <button type="submit" class="btn text-white fw-semibold rounded-pill px-4" style="background-color: var(--admin-primary);">Save All Settings</button>
                    </div>
                </div>
                
                <!-- Other Nav panes can be implemented similarly or left empty for now -->
                <div class="tab-pane fade" id="moderation" role="tabpanel">...</div>
                <div class="tab-pane fade" id="email" role="tabpanel">...</div>
                <div class="tab-pane fade" id="account" role="tabpanel">...</div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        // JS to handle tab active state styling
        document.querySelectorAll('button[data-bs-toggle="tab"]').forEach(tab => {
            tab.addEventListener('shown.bs.tab', event => {
                // Reset all tabs
                document.querySelectorAll('button[data-bs-toggle="tab"]').forEach(t => {
                    t.style.borderBottom = 'none';
                    t.classList.remove('text-dark', 'fw-semibold');
                    t.classList.add('text-muted');
                    t.style.color = '';
                });
                
                // Style active tab
                event.target.style.borderBottom = '2px solid var(--admin-primary)';
                event.target.classList.remove('text-muted');
                event.target.classList.add('text-dark', 'fw-semibold');
                event.target.style.color = 'var(--admin-primary)';
            });
        });
    </script>
}