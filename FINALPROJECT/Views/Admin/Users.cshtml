@model FINALPROJECT.ViewModels.Admin.AdminUsersViewModel
@{
    ViewData["Title"] = "Manage Users";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-pill px-4 mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-pill px-4 mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <!-- Main Content -->
    <div class="col-lg-8">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <h1 class="admin-page-title mb-0">Manage Users</h1>
                <p class="text-muted small">Monitor user activity, manage account statuses, and moderate community profiles.</p>
            </div>
            <button class="btn btn-dark rounded-pill px-3"><i class="bi bi-download me-1"></i> Export User Data</button>
        </div>

        <div class="stat-card mb-4 p-3 d-flex gap-3 align-items-center bg-light border-0">
            <div class="input-group flex-grow-1" style="max-width: 400px;">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" class="form-control border-start-0 ps-0" placeholder="Search by name, email, or username...">
            </div>
            <select class="form-select w-auto"><option>All Statuses</option></select>
            <select class="form-select w-auto"><option>Sort By: Newest</option></select>
            <button class="btn btn-dark ms-auto"><i class="bi bi-sliders"></i></button>
        </div>

        <div class="stat-card p-0 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="text-muted small text-uppercase" style="font-size: 0.70rem;">
                        <tr>
                            <th class="ps-4">User Profile</th>
                            <th>Email Address</th>
                            <th>Recipes</th>
                            <th>Join Date</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody style="font-size: 0.85rem;">
                        @foreach (var u in Model.Users)
                        {
                            var isBanned = u.LockoutEnd != null && u.LockoutEnd > DateTimeOffset.UtcNow;
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-2">
                                        <img src="/files/default-avatar.png" class="rounded-circle" width="32" height="32" />
                                        <div>
                                            <div class="fw-bold text-dark">@u.DisplayName</div>
                                            <div class="text-muted small">@u.UserName</div>
                                        </div>
                                    </div>
                                </td>
                                <td>@u.Email</td>
                                <td class="fw-semibold" style="color: var(--admin-primary)">@(u.Recipes?.Count ?? 0)</td>
                                <td>
                                    <div>@u.CreatedAt.ToString("MMM dd,")</div>
                                    <div class="text-muted small">@u.CreatedAt.ToString("yyyy")</div>
                                </td>
                                <td>
                                    @if (isBanned)
                                    {
                                        <span class="fw-bold text-danger animate-pulse" style="font-size: 0.75rem;">BANNED</span>
                                    }
                                    else
                                    {
                                        <span class="fw-bold text-success" style="font-size: 0.75rem;">ACTIVE</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-inline-flex align-items-center gap-1">
                                        <!-- Promote/Demote button -->
                                        <form asp-action="Promote" asp-controller="Admin" asp-route-id="@u.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-light border rounded px-2 text-muted" style="font-size: 0.7rem;" title="Toggle Admin Role">
                                                ROLE
                                            </button>
                                        </form>

                                        <!-- Ban/Unban button -->
                                        <form asp-action="ToggleBan" asp-controller="Admin" asp-route-id="@u.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to change this user\'s access status?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-link @(isBanned ? "text-success" : "text-danger") p-1" title="@(isBanned ? "Unban User" : "Ban User")" style="text-decoration: none;">
                                                <i class="bi @(isBanned ? "bi-check-circle-fill text-success" : "bi-ban text-danger")"></i>
                                            </button>
                                        </form>

                                        <!-- Delete button (except self) -->
                                        @if (u.Id != User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                                        {
                                            <form asp-action="DeleteUser" asp-controller="Admin" asp-route-id="@u.Id" method="post" class="d-inline" onsubmit="return confirm('Are you absolutely sure you want to delete this user permanently? This cannot be undone.');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-link text-danger p-1" title="Delete User">
                                                    <i class="bi bi-trash-fill text-danger"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination Mock -->
            <div class="p-3 border-top d-flex justify-content-between align-items-center bg-light">
                <div class="small text-muted">Showing <strong>1 - @(Math.Min(10, Model.TotalCount))</strong> of <strong>@Model.TotalCount.ToString("N0")</strong> users</div>
                <div class="d-flex gap-1">
                    <button class="btn btn-sm btn-light border">&lt;</button>
                    <button class="btn btn-sm text-white border" style="background-color: var(--admin-primary);">1</button>
                    <button class="btn btn-sm btn-light border">2</button>
                    <button class="btn btn-sm btn-light border">3</button>
                    <span class="px-2 text-muted">...</span>
                    <button class="btn btn-sm btn-light border">&gt;</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Side Panel / User Summary -->
    <div class="col-lg-4">
        <div class="stat-card position-sticky" style="top: 2rem;">
            <h6 class="fw-bold mb-4">User Statistics</h6>
            
            <div class="row text-center mb-4 g-2">
                <div class="col-4">
                    <div class="border rounded p-2 bg-light">
                        <div class="fw-bold fs-5">@Model.TotalCount</div>
                        <div class="text-muted" style="font-size: 0.65rem; letter-spacing: 1px;">TOTAL</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="border rounded p-2 bg-light">
                        <div class="fw-bold fs-5">@Model.Users.Count(u => u.CreatedAt >= DateTime.UtcNow.AddDays(-7))</div>
                        <div class="text-muted" style="font-size: 0.65rem; letter-spacing: 1px;">NEW (7D)</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="border rounded p-2 bg-light">
                        <div class="fw-bold fs-5 text-danger">@Model.Users.Count(u => u.LockoutEnd != null && u.LockoutEnd > DateTimeOffset.UtcNow)</div>
                        <div class="text-muted" style="font-size: 0.65rem; letter-spacing: 1px;">BANNED</div>
                    </div>
                </div>
            </div>

            <div class="border-top pt-3">
                <div class="fw-bold small mb-3">Quick Actions</div>
                <a asp-controller="Admin" asp-action="Reviews" class="btn btn-dark w-100 rounded-pill mb-2 py-2"><i class="bi bi-shield-exclamation me-2"></i> View Reports</a>
                <a asp-controller="Admin" asp-action="Settings" class="btn w-100 rounded-pill border-0 py-2" style="background-color: #fee2e2; color: #dc2626;"><i class="bi bi-gear me-2"></i> Platform Settings</a>
            </div>
        </div>
    </div>
</div>