@model FINALPROJECT.ViewModels.Admin.AdminAnalyticsViewModel
@{
    ViewData["Title"] = "Analytics";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="admin-page-title mb-0">Analytics</h1>
        <p class="text-muted small">Detailed performance insights and community growth metrics.</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-white bg-white border shadow-sm px-4 rounded-pill"><i class="bi bi-calendar3 me-2 text-muted"></i> Last 6 Months</button>
        <button class="btn text-white px-4 rounded-pill shadow-sm" style="background-color: var(--admin-primary); border-color: var(--admin-primary);"><i class="bi bi-download me-2"></i> Export PDF</button>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Line Chart: Community Growth -->
    <div class="col-lg-8">
        <div class="stat-card h-100">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h6 class="fw-bold mb-0">Community Growth</h6>
                <div class="d-flex gap-3 small">
                    <div class="d-flex align-items-center gap-1"><i class="bi bi-circle-fill" style="color: var(--admin-primary); font-size: 8px;"></i> Users</div>
                    <div class="d-flex align-items-center gap-1"><i class="bi bi-circle-fill text-dark" style="font-size: 8px;"></i> Recipes</div>
                </div>
            </div>
            <div style="height: 300px;">
                <canvas id="communityGrowthChart"></canvas>
            </div>
        </div>
    </div>
    <!-- Doughnut Chart: Difficulty Distribution -->
    <div class="col-lg-4">
        <div class="stat-card h-100">
            <h6 class="fw-bold mb-4">Difficulty Distribution</h6>
            <div class="d-flex justify-content-center align-items-center" style="height: 250px;">
                <canvas id="difficultyChart"></canvas>
            </div>
            <!-- Labels rendered directly by Chart.js in mockup -->
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-12">
        <div class="stat-card">
            <h6 class="fw-bold mb-4">Recipes by Category</h6>
            <div style="height: 250px;">
                <canvas id="categoryChart"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-5">
    <!-- Top Contributors -->
    <div class="col-lg-5">
        <div class="stat-card h-100 p-0 overflow-hidden">
            <div class="p-4 border-bottom d-flex align-items-center justify-content-between">
                <h6 class="mb-0 fw-bold">Top Contributors</h6>
                <span class="text-uppercase fw-bold text-muted" style="font-size: 0.65rem; color: var(--admin-primary) !important;">MOST ACTIVE</span>
            </div>
            <div class="table-responsive">
                <table class="table align-middle mb-0 border-white">
                    <tbody>
                        @{ int rank = 1; }
                        @foreach(var user in Model.TopContributors)
                        {
                            <tr class="border-bottom-0">
                                <td class="ps-4 text-muted small" style="width: 30px;">@rank</td>
                                <td style="width: 50px;"><img src="/files/default-avatar.png" class="rounded-circle" width="36" height="36" /></td>
                                <td>
                                    <div class="fw-bold text-dark" style="font-size: 0.85rem;">@user.DisplayName</div>
                                    <div class="text-muted" style="font-size: 0.7rem;">Chef</div>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="fw-bold" style="color: var(--admin-primary);">@(user.Recipes?.Count ?? 0)</div>
                                    <div class="text-muted" style="font-size: 0.65rem;">Recipes</div>
                                </td>
                            </tr>
                            rank++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    
    <!-- Trending Content -->
    <div class="col-lg-7">
        <div class="stat-card h-100 p-0 overflow-hidden">
            <div class="p-4 border-bottom d-flex align-items-center justify-content-between">
                <h6 class="mb-0 fw-bold">Trending Content</h6>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="text-muted small text-uppercase bg-white border-bottom" style="font-size: 0.65rem;">
                        <tr>
                            <th class="ps-4 fw-bold">Video</th>
                            <th class="fw-bold">Chef</th>
                            <th class="fw-bold">Views</th>
                            <th class="fw-bold text-end pe-4">Engagement</th>
                        </tr>
                    </thead>
                    <tbody style="font-size: 0.85rem;">
                        @foreach(var video in Model.TrendingVideos)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-3 py-1">
                                        <img src="@video.ThumbnailUrl" class="rounded" width="48" height="32" style="object-fit:cover" />
                                        <div class="fw-bold text-dark">@video.Title</div>
                                    </div>
                                </td>
                                <td class="text-muted small">@(video.Author?.DisplayName ?? "Unknown")</td>
                                <td class="fw-bold text-dark">@(video.ViewCount / 1000.0)K</td>
                                <td class="pe-4 align-middle">
                                    <div class="progress bg-light" style="height: 6px; width: 80px; float: right;">
                                        <div class="progress-bar" style="width: 80%; background-color: #20c997;" role="progressbar"></div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var growthLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.GrowthLabels));
            var monthlyUsersData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyUsers));
            var monthlyRecipesData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyRecipes));

            // Community Growth Line Chart
            var ctxGrowth = document.getElementById('communityGrowthChart').getContext('2d');
            new Chart(ctxGrowth, {
                type: 'line',
                data: {
                    labels: growthLabels,
                    datasets: [
                        {
                            label: 'Users',
                            data: monthlyUsersData,
                            borderColor: '#dd6e35',
                            backgroundColor: 'transparent',
                            borderWidth: 3,
                            tension: 0.4,
                            pointBackgroundColor: '#dd6e35',
                            pointRadius: 4
                        },
                        {
                            label: 'Recipes',
                            data: monthlyRecipesData,
                            borderColor: '#2c2520',
                            backgroundColor: 'transparent',
                            borderWidth: 3,
                            tension: 0.4,
                            pointBackgroundColor: '#2c2520',
                            pointRadius: 4
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: '#f0e9e1' }, border: { display: false } },
                        x: { grid: { display: false }, border: { display: false } }
                    }
                }
            });

            // Difficulty Doughnut Chart
            var ctxDiff = document.getElementById('difficultyChart').getContext('2d');
            new Chart(ctxDiff, {
                type: 'doughnut',
                data: {
                    labels: ['Easy', 'Medium', 'Advanced'],
                    datasets: [{
                        data: [@Model.EasyCount, @Model.MediumCount, @Model.AdvancedCount],
                        backgroundColor: ['#20c997', '#dd6e35', '#2c2520'],
                        borderWidth: 0,
                        cutout: '65%'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { 
                        legend: { display: false } 
                    }
                }
            });

            // Categories Bar Chart
            var categoryLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CategoryLabels));
            var categoryCounts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CategoryCounts));

            var ctxCat = document.getElementById('categoryChart').getContext('2d');
            new Chart(ctxCat, {
                type: 'bar',
                data: {
                    labels: categoryLabels,
                    datasets: [{
                        data: categoryCounts,
                        backgroundColor: '#dd6e35',
                        borderRadius: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: '#f0e9e1' }, border: { display: false } },
                        x: { grid: { display: false }, border: { display: false } }
                    }
                }
            });
        });
    </script>
}