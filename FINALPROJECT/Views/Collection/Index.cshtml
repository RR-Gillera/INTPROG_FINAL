@model FINALPROJECT.ViewModels.CollectionViewModel
@{
    ViewData["Title"] = "Collections";
}

<div class="container py-5">
    <!-- Header -->
    <div class="d-flex align-items-start justify-content-between mb-2">
        <div>
            <div class="section-eyebrow">CURATED BY YOU</div>
            <h1 class="fw-bold mt-1">Your Collections</h1>
        </div>
        <button class="btn btn-primary-flavorly rounded-pill px-4 py-2 fw-semibold"
                data-bs-toggle="modal" data-bs-target="#createCollectionModal">
            <i class="bi bi-plus me-1"></i>Create Collection
        </button>
    </div>

    <!-- Featured Highlights -->
    @if (Model.Featured.Any())
    {
        <h5 class="fw-bold mb-3 mt-4">Featured Highlights</h5>
        <div class="row g-4 mb-2">
            @foreach (var col in Model.Featured.Take(2))
            {
                var imgs = col.CollectionRecipes
                    .Where(cr => cr.Recipe != null)
                    .Select(cr => cr.Recipe!.HeroImageUrl)
                    .Take(4).ToList();
                while (imgs.Count < 4)
                    imgs.Add("https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=200&q=80");

                <div class="col-md-6">
                    <div class="position-relative rounded-3 overflow-hidden" style="height:260px;cursor:pointer;">
                        <div class="mosaic-grid h-100">
                            @foreach (var img in imgs)
                            {
                                <img src="@img" alt="collection"
                                     onerror="this.src='https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=200&q=80'" />
                            }
                        </div>
                        <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.7) 40%,transparent);display:flex;align-items:flex-end;padding:1.25rem;">
                            <div>
                                <h5 class="text-white mb-1">@col.Name</h5>
                                <small class="text-white opacity-75">@col.CollectionRecipes.Count items · @col.Owner?.DisplayName</small>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- Category Tabs -->
    <div class="d-flex gap-2 flex-wrap mt-4 mb-4">
        @foreach (var tab in new[] { "Trending", "My Collections", "Saved", "Pastry Arts", "Wine Pairing", "Quick Bites" })
        {
            <a asp-controller="Collection" asp-action="Index" asp-route-tab="@tab"
               class="tab-pill @(Model.ActiveTab == tab ? "active" : "")">@tab</a>
        }
        <a asp-controller="Collection" asp-action="Index" class="tab-pill">View All</a>
    </div>

    <!-- Collection Cards -->
    @if (!Model.Collections.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon"><i class="bi bi-collection"></i></div>
            <h4>No collections yet</h4>
            <p class="text-muted">Create your first collection to organise your favourite recipes.</p>
            <button class="btn btn-primary-flavorly rounded-pill px-4"
                    data-bs-toggle="modal" data-bs-target="#createCollectionModal">
                <i class="bi bi-plus me-1"></i>Create Collection
            </button>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var col in Model.Collections)
            {
                var thumb = col.CollectionRecipes.FirstOrDefault()?.Recipe?.HeroImageUrl
                          ?? col.CoverImageUrl;
                <div class="col-md-6 col-lg-4">
                    <div class="collection-card">
                        <div class="position-relative" style="height:200px;overflow:hidden;">
                            <img src="@thumb" alt="@col.Name" style="width:100%;height:100%;object-fit:cover;"
                                 onerror="this.src='https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=400&q=80'" />
                            <span class="badge rounded-pill position-absolute"
                                  style="top:10px;left:10px;background:rgba(28,22,18,.8);color:#fff;font-size:.7rem;backdrop-filter:blur(4px);">
                                @col.CollectionRecipes.Count RECIPES
                            </span>
                            <button class="card-bookmark"><i class="bi bi-bookmark"></i></button>
                        </div>
                        <div class="p-4">
                            <h6 class="fw-bold mb-1">@col.Name</h6>
                            <p class="text-muted small mb-3" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                                @col.Description
                            </p>
                            <div class="d-flex align-items-center justify-content-between">
                                <div class="d-flex">
                                    <img src="@(col.Owner?.AvatarUrl ?? "/images/default-avatar.png")"
                                         class="rounded-circle" width="26" height="26" style="object-fit:cover;border:2px solid #fff;"
                                         onerror="this.src='https://ui-avatars.com/api/?name=U&background=E8E2DA&size=26'" alt="owner"/>
                                </div>
                                <span class="small text-muted">@col.Owner?.DisplayName</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="text-center mt-5">
            <button class="btn btn-outline-secondary rounded-pill px-4 py-2">Explore More Collections</button>
            <div class="text-muted small mt-2">SHOWING @Model.Collections.Count() OF @Model.TotalCount CURATED COLLECTIONS</div>
        </div>
    }
</div>

<!-- Create Collection Modal -->
<div class="modal fade" id="createCollectionModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow-lg">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Create Collection</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-controller="Collection" asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body py-3">
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Collection Name</label>
                        <input type="text" name="name" class="form-control rounded-3" placeholder="e.g. Sunday Brunch Favourites" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Description</label>
                        <textarea name="description" class="form-control rounded-3" rows="3"
                                  placeholder="What's this collection about?"></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary-flavorly rounded-pill px-4 fw-semibold">Create Collection</button>
                </div>
            </form>
        </div>
    </div>
</div>
